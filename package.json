{
  "name": "anti-frontrunner",
  "private": true,
  "scripts": {
    "build": "tailwindcss -i ./src/input.css -o ./assets/tailwind.css --minify",
    "build:css": "npm run build",
    "generate:favicons": "node scripts/generate-favicons.mjs",
    "generate:og": "node scripts/capture-og-screenshot.mjs",
    "generate:assets": "npm run generate:favicons && npm run generate:og"
  },
  "devDependencies": {
    "playwright": "^1.61.0",
    "sharp": "^0.35.2",
    "tailwindcss": "^3.4.17"
  }
}
